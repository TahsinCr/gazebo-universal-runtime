# Copy this file to .env and adjust values for your machine.
# Docker Compose and the launcher scripts automatically read .env.

# Image build
GAZEBO_IMAGE=gazebo-universal-runtime:local

# Ubuntu 24.04 is the recommended base for all supported collections.
UBUNTU_VERSION=24.04

# Full Gazebo package: gz-jetty, gz-ionic, or gz-harmonic.
GAZEBO_PACKAGE=gz-jetty
GAZEBO_APT_REPOSITORY=https://packages.osrfoundation.org/gazebo/ubuntu-stable

# Default simulation
GAZEBO_WORLD=/sim/worlds/default.sdf
GAZEBO_ARGS="-v 2"
GZ_PARTITION=gazebo

# Project resource paths inside the container
GZ_SIM_RESOURCE_PATH=/sim/worlds:/sim/models
GZ_SIM_SYSTEM_PLUGIN_PATH=/sim/plugins
GZ_GUI_PLUGIN_PATH=/sim/plugins
GZ_GUI_RESOURCE_PATH=/sim/worlds:/sim/models
GAZEBO_WEB_GUI_TEMPLATE=/sim/gz-web-gui.config

# Web backend: optimized low-latency defaults
WEB_BIND_ADDRESS=127.0.0.1
WEB_LISTEN_ADDRESS=0.0.0.0
WEB_PORT=6080
GAZEBO_WEB_PROFILE=fast
VNC_GEOMETRY=1600x900
VNC_DEPTH=24
VNC_FRAME_RATE=60
VNC_COMPARE_FB=0
VNC_ZLIB_LEVEL=0
VNC_IMPROVED_HEXTILE=0
VNC_PIXEL_FORMAT=rgb888
VNC_PASSWORD=
WEB_HEARTBEAT=30

# Renderer and readiness checks
GAZEBO_GPU_MODE=auto
GAZEBO_ALLOW_SOFTWARE=0
GAZEBO_REQUIRE_GPU=0
GAZEBO_VERIFY_RENDERER=0
GAZEBO_REQUIRE_3D_VIEW=1
LIBGL_ALWAYS_SOFTWARE=0
QSG_RHI_BACKEND=opengl
MESA_GLTHREAD=true

# Runtime startup and shared-memory budget
GAZEBO_START_TIMEOUT=90
GAZEBO_SHM_SIZE=512m

# Native Linux UI
GAZEBO_UI_BACKEND=
GAZEBO_WAYLAND_NATIVE=0
